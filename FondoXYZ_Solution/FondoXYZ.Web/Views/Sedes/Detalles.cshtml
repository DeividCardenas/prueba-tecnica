@model FondoXYZ.Domain.Entities.Sede

@{
    ViewData["Title"] = "Detaille del Destino";
}

<div class="container mt-2">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-link link-secondary text-decoration-none p-0 d-inline-flex align-items-center fw-semibold small">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left me-1" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z" />
            </svg>
            Volver al catálogo de destinos
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden mb-5">
        <div class="p-4 p-md-5 text-white @(Model.Tipo == "Apartamento" ? "bg-info bg-gradient" : "bg-primary bg-gradient")">
            <div class="row align-items-center g-3">
                <div class="col-md-8">
                    <span class="badge bg-white text-dark rounded-pill fw-bold text-uppercase px-3 py-2 small mb-3 shadow-sm">
                        @Model.Tipo
                    </span>
                    <h1 class="display-6 fw-bold mb-2">@Model.Nombre</h1>
                    <div class="d-flex align-items-center text-white-50">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-geo-alt-fill me-2 text-danger" viewBox="0 0 16 16">
                            <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z" />
                        </svg>
                        <span class="fw-medium">@Model.Ubicacion</span>
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="bg-white bg-opacity-10 p-3 rounded-3 d-inline-block text-center border border-white border-opacity-10">
                        <span class="d-block small text-white-50 text-uppercase fw-bold">Capacidad Sede</span>
                        <span class="fs-3 fw-bold">@Model.CapacidadMaxima <small class="fs-6 fw-normal">Ps. Máx</small></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-4 bg-white">
            <h5 class="fw-bold text-dark mb-2">Acerca de este lugar</h5>
            <p class="text-secondary mb-0">
                @* CORREGIDO: Se cambió Model.Description por Model.Descripcion *@
                @(string.IsNullOrEmpty(Model.Descripcion) ? "Este destino cuenta con todas las comodidades y estándares logísticos establecidos por el comité de bienestar para garantizar una experiencia placentera y segura a nuestros afiliados." : Model.Descripcion)
            </p>
        </div>
    </div>

    <div class="border-bottom pb-2 mb-4">
        <h4 class="fw-bold text-dark mb-0">Alojamientos y Unidades Habitacionales</h4>
        <p class="text-muted small mb-0">Selecciona el tipo de cabaña o habitación que se ajuste a tus necesidades familiares para consultar sus tarifas vigentes.</p>
    </div>

    @if (Model.Alojamientos == null || !Model.Alojamientos.Any())
    {
        <div class="alert alert-warning border-0 shadow-sm p-4 text-center rounded-3" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-exclamation-triangle-fill text-warning mb-2" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
            <h5 class="fw-bold mb-1">No hay alojamientos disponibles</h5>
            <p class="text-muted small mb-0">Actualmente no se encuentran unidades configuradas o activas para esta sede en la base de datos.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var aloj in Model.Alojamientos)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm bg-white rounded-3 overflow-hidden custom-aloj-card">
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5 class="fw-bold text-dark mb-0 text-truncate-1">@aloj.Nombre</h5>
                                    <span class="badge @(aloj.EstadoDisponible ? "bg-success-subtle text-success border border-success-subtle" : "bg-danger-subtle text-danger border border-danger-subtle") rounded-pill px-2 py-1 small fw-semibold">
                                        @(aloj.EstadoDisponible ? "Activo" : "Mantenimiento")
                                    </span>
                                </div>

                                <div class="d-flex gap-2 mb-3 flex-wrap">
                                    <span class="badge bg-light text-secondary border rounded-2 px-2 py-1.5 small fw-medium">
                                        🛌 @aloj.NumeroHabitaciones @(aloj.NumeroHabitaciones == 1 ? "Habitación" : "Habitaciones")
                                    </span>
                                    <span class="badge bg-light text-secondary border rounded-2 px-2 py-1.5 small fw-medium">
                                        👥 Máx @aloj.CapacidadMaxima Personas
                                    </span>
                                </div>

                                <p class="text-secondary small card-aloj-desc mb-4">
                                    @(string.IsNullOrEmpty(aloj.Descripcion) ? "Unidad vacacional totalmente dotada con lencería de cama, baño privado y conectividad de entretenimiento estándar." : aloj.Descripcion)
                                </p>
                            </div>

                            <div class="border-top pt-3">
                                <div class="d-grid">
                                    <a asp-action="ConsultarTarifas"
                                       asp-route-sedeId="@Model.Id"
                                       asp-route-alojamientoId="@aloj.Id"
                                       class="btn btn-outline-primary fw-bold text-uppercase tracking-wider py-2 rounded-2 btn-action-tarifa @(aloj.EstadoDisponible ? "" : "disabled")">
                                        Consultar Tarifas
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <style>
        /* Sincronización del efecto hover con el catálogo principal */
        .custom-aloj-card {
            transition: transform 0.3s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.3s ease;
        }

            .custom-aloj-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.08) !important;
            }

        .btn-action-tarifa {
            font-size: 0.75rem;
            transition: all 0.2s ease;
        }
        /* Limitador simétrico para las descripciones de los alojamientos */
        .card-aloj-desc {
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
            height: 4.8rem; /* Sincroniza la visualización de los bloques fijos */
        }

        .text-truncate-1 {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 75%;
        }
    </style>
}