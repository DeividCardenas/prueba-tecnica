@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = null; // Pantalla de acceso independiente sin el menú principal
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fondo XYZ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            /* Estilos personalizados para el Split-Screen de Recuperación */
            .bg-recovery-image {
                background: linear-gradient(135deg, #3a6073 0%, #3a7bd5 100%);
                color: white;
            }

            .form-control:focus {
                border-color: #3a6073;
                box-shadow: 0 0 0 0.25rem rgba(58, 96, 115, 0.25);
            }

            .btn-danger {
                background-color: #e53935;
                border-color: #e53935;
                padding: 12px;
                transition: all 0.3s ease;
            }

                .btn-danger:hover {
                    background-color: #d32f2f;
                    border-color: #d32f2f;
                    transform: translateY(-1px);
                }
    </style>
</head>
<body class="bg-light">

    <div class="container-fluid ps-md-0">
        <div class="row g-0">
            <div class="d-none d-md-flex col-md-5 col-lg-6 bg-recovery-image align-items-center justify-content-center p-5 text-center shadow-lg">
                <div>
                    <h1 class="display-4 fw-bold mb-4">¿Problemas de Acceso?</h1>
                    <p class="lead mb-5">No te preocupes. Introduce tu dirección de correo electrónico institucional o registrada y el sistema automatizado SMTP te enviará de inmediato una credencial de acceso temporal de alta seguridad.</p>
                    <div class="mt-5">
                        <span class="badge bg-light text-dark p-2 fs-6 rounded-pill shadow-sm">Recuperación Automatizada</span>
                    </div>
                </div>
            </div>

            <div class="col-md-7 col-lg-6">
                <div class="login d-flex align-items-center py-5" style="min-height: 100vh;">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-md-10 col-lg-8">

                                <h3 class="login-heading mb-2 fw-bold text-dark">Restablecer Contraseña</h3>
                                <p class="text-muted mb-4">Ingresa tu correo para recibir una clave temporal de inicio de sesión.</p>

                                @* Alerta de Éxito (Si el correo existía y el SP/SMTP procesó todo bien) *@
                                @if (ViewBag.Exito != null)
                                {
                                    <div class="alert alert-success shadow-sm border-0 border-start border-success border-4 small mb-4" role="alert">
                                        <span class="fw-bold">@ViewBag.Exito</span>
                                    </div>
                                }

                                @* Alerta de Error (Si el correo no existe en la base de datos) *@
                                @if (ViewBag.Error != null)
                                {
                                    <div class="alert alert-danger shadow-sm border-0 border-start border-danger border-4 small mb-4" role="alert">
                                        <span class="fw-bold">@ViewBag.Error</span>
                                    </div>
                                }

                                <form asp-action="RecuperarClave" method="post">
                                    @Html.AntiForgeryToken()

                                    <div class="form-floating mb-4">
                                        <input name="email" id="email" type="email" class="form-control rounded-3 border-light shadow-sm" placeholder="nombre@ejemplo.com" required autocomplete="email" />
                                        <label for="email" class="text-muted">Correo Electrónico Registrado</label>
                                        <div class="form-text small text-muted px-1 mt-2">
                                            Asegúrate de revisar la carpeta de Spam o Correo no deseado tras realizar la solicitud.
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <button class="btn btn-danger btn-lg rounded-3 shadow text-uppercase fw-bold text-white" type="submit">Generar Clave Temporal</button>
                                    </div>

                                    <hr class="my-4 text-muted">

                                    <div class="text-center">
                                        <span class="text-muted small">¿Recordaste tus credenciales?</span>
                                        <a class="text-primary fw-bold text-decoration-none small" asp-action="Login">Regresar al Login</a>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>